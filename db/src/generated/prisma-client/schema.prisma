  id                      BigInt   @default(autoincrement())
  client_id               BigInt
  actor_user_id           BigInt?
  actor_api_key_id        BigInt?
  actor_type              String?
  actor_role              String?
  acting_via_control_view Boolean  @default(false)
  impersonator_user_id    BigInt?
  control_view_session_id BigInt?
  action                  String
  entity_type             String
  entity_id               BigInt?
